{
  "name": "better-code-soul",
  "version": "0.1.0",
  "description": "Cost, quality and routing layer for coding agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "better-code-soul": "dist/cli.js",
    "bcs": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "postinstall": "node scripts/postinstall.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "blessed": "'~'0.1.81",
    "blessed-contrib": "'~'4.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/blessed": "'~'0.1.27",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "opencode",
    "codex",
    "claude-code",
    "plugin",
    "token",
    "mcp",
    "ai",
    "graphify",
    "context-mode",
    "subagent",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devGibi/better-code-soul.git"
  },
  "files": [
    "dist",
    "scripts",
    "configs",
    "assets",
    "src/models"
  ]
}
